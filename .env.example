# ─── App ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Generate with PowerShell:
# [System.Convert]::ToBase64String([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(32))
CRON_SECRET=replace-with-output-of-command-above

# ─── Database (Supabase) ────────────────────────────────────────────────────
# Use the Transaction pooler connection string (port 6543) for DATABASE_URL
# Use the Session pooler connection string (port 5432) for DIRECT_URL
# If your password contains @ # $ % & — URL-encode those characters
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# ─── Auth (Clerk) ───────────────────────────────────────────────────────────
# Use TEST keys (pk_test_ / sk_test_) for local development and staging.
# Switch to LIVE keys (pk_live_ / sk_live_) only when ready for real users.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
# Add this after deploying — copy from Clerk dashboard > Webhooks > Signing secret
CLERK_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ─── AI (Anthropic) ─────────────────────────────────────────────────────────
# Set a spend limit in the Anthropic console under Billing > Limits
ANTHROPIC_API_KEY=sk-ant-...

# ─── Transcription (OpenAI Whisper) ─────────────────────────────────────────
# Set a spend limit in the OpenAI dashboard under Settings > Limits
OPENAI_API_KEY=sk-...

# ─── Rate Limiting (Upstash Redis) ──────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://....upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# ─── Billing (Stripe) ────────────────────────────────────────────────────────
# Use TEST keys and TEST price IDs for local development.
# All test key IDs start with sk_test_ / pk_test_ / price_ (created in test mode).
# Do not mix test keys with live price IDs or vice versa.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Create these products in Stripe dashboard (test mode) before running locally
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_YEARLY_PRICE_ID=price_...
STRIPE_AGENCY_MONTHLY_PRICE_ID=price_...
STRIPE_AGENCY_YEARLY_PRICE_ID=price_...
